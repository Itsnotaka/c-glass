{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    "dist-electron",
    "node_modules",
    "pnpm-lock.yaml",
    "*.tsbuildinfo",
    "**/routeTree.gen.ts",
    ".pi/**",
    ".config/oxlint-glass-plugin.mjs"
  ],
  "plugins": ["eslint", "oxc", "react", "unicorn", "typescript"],
  "jsPlugins": ["./oxlint-glass-plugin.mjs"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react-in-jsx-scope": "off",
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off",
    "glass/no-tiny-wrapper-function": "warn",
    "glass/no-unknown-function-type": "off",
    "typescript/no-restricted-types": "off"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "rules": {
        "glass/no-tiny-wrapper-function": "off"
      }
    },
    {
      "files": [
        "**/apps/desktop/src/pi-runtime/pi-rpc-client.ts",
        "**/apps/desktop/src/pi-runtime/pi-runtime-service.ts"
      ],
      "rules": {
        "glass/no-tiny-wrapper-function": "off"
      }
    },
    {
      "files": [
        "**/packages/contracts/src/session.ts",
        "**/apps/desktop/src/main.ts",
        "**/apps/desktop/src/preload.ts",
        "**/apps/desktop/src/cursor-provider.ts",
        "**/apps/desktop/src/pi-runtime/pi-rpc-types.ts",
        "**/apps/desktop/src/pi-runtime/pi-runtime-normalizer.ts",
        "**/apps/desktop/src/pi-runtime/pi-runtime-store.ts",
        "**/apps/desktop/src/pi-runtime/pi-read-cache.ts",
        "**/apps/desktop/src/pi-runtime/pi-runtime-service.ts",
        "**/build-desktop-artifact.ts",
        "**/update-release-package-versions.ts"
      ],
      "rules": {
        "typescript/no-restricted-types": "off",
        "glass/no-unknown-function-type": "off"
      }
    }
  ]
}

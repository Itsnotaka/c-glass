{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "dist",
    "dist-electron",
    "node_modules",
    "pnpm-lock.yaml",
    "*.tsbuildinfo",
    "**/routeTree.gen.ts",
    ".pi/**",
    ".config/oxlint-glass-plugin.mjs"
  ],
  "plugins": ["eslint", "oxc", "react", "unicorn", "typescript"],
  "jsPlugins": ["./oxlint-glass-plugin.mjs"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react-in-jsx-scope": "off",
    "eslint/no-shadow": "off",
    "eslint/no-await-in-loop": "off",
    "glass/no-tiny-wrapper-function": "warn",
    "glass/no-unknown-function-type": "warn",
    "typescript/no-restricted-types": [
      "warn",
      {
        "types": {
          "unknown": "Avoid `unknown` as a broad type escape hatch. Prefer concrete shapes or validated parser outputs. Prefer type inference over explicit `unknown`."
        }
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "rules": {
        "glass/no-tiny-wrapper-function": "off"
      }
    }
  ]
}
